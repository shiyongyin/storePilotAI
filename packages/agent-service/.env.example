# ============================================================================
# 门店助手 Agent V1 — agent-service 环境变量(23 基础字段 + 1 安全开关,不含真实值)
# 严格按 docs/任务卡/A-基础设施.md §T-INFRA-04 §5.1 表对齐。
# ============================================================================

# --- 运行模式与端口 -----------------------------------------------------------
NODE_ENV=development
PORT=7100

# --- MySQL 连接(切片 03 落库)-----------------------------------------------
DATABASE_URL=mysql://user:change-me@localhost:3306/store_pilot?timezone=Z&dateStrings=true&supportBigNumbers=true&bigNumberStrings=true&charset=utf8mb4&decimalNumbers=true

# --- LLM 模型(切片 06)------------------------------------------------------
MODEL_PROVIDER=openai-compatible
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=sk-change-me-please-replace
MODEL_NAME=gpt-4-turbo
MODEL_TIMEOUT_MS=25000
MAX_OUTPUT_TOKENS=4096
MAX_TOOL_CALLS_PER_REQUEST=8

# --- MCP(切片 05/08)---------------------------------------------------------
ERP_MCP_SERVER_URL=http://localhost:7300/mcp
MCP_TENANT_SHARED_SECRET=change-me-32-char-secret-xxxxxxxxxx
MCP_PROTOCOL_VERSION=2025-06-18
TOOL_CALL_TIMEOUT_MS=15000

# --- DB Pool(切片 07)-------------------------------------------------------
DB_POOL_MAX=20
DB_QUEUE_LIMIT=200

# --- API Key 鉴权(切片 09)-------------------------------------------------
AGENT_API_KEY_HASH_SALT=change-me-16char
AGENT_API_KEY_PREFIX=sk-agent-

# --- 桥接层(切片 09/10)---------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3210,http://localhost:3000
USER_MESSAGE_MAX_CHARS=4000

# --- HITL / 草稿过期(切片 13/16)------------------------------------------
SUSPEND_TTL_MINUTES=30

# --- 留存(切片 20/21)-----------------------------------------------------
RETENTION_DAYS_RUN_LOG=180

# --- 安全校验(切片 11;生产禁止关闭)---------------------------------------
NUMBER_CONSISTENCY_CHECK_ENABLED=true

# --- 可观测性(可选;留占位 URL,本地不需要时可置空)-------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
