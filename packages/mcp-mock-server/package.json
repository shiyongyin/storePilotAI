    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "import": "./dist/test-utils.js"
    }
  },
  "scripts": {
